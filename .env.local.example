# =================================================================
# PsicoApp — Variables de entorno
# Copiá este archivo como ".env.local" y completá los valores.
# NUNCA subas .env.local a git (ya está en .gitignore).
# =================================================================

# ── Supabase ──────────────────────────────────────────────────────
# Encontrás estos valores en: Supabase Dashboard → Settings → API

# URL pública del proyecto (usada en el browser y en el middleware)
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co

# Anon key (pública, usada en el browser — está protegida por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# URL del proyecto (usada en el servidor con la service role key)
# Puede ser la misma que NEXT_PUBLIC_SUPABASE_URL
SUPABASE_URL=https://TU_PROYECTO.supabase.co

# Service role key (SECRETA — nunca exponer al browser)
# Bypassa RLS y tiene acceso total a la base de datos
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ── OpenAI ────────────────────────────────────────────────────────
# Encontrás esto en: platform.openai.com → API Keys
# Usada SOLO en el servidor (transcripción + resúmenes)
OPENAI_API_KEY=sk-proj-...

# ── Upstash Redis (Rate Limiting) ──────────────────────────────────
# REQUERIDO en producción — la app no arranca sin esto.
# Creá una database gratuita en: upstash.com → Console → Create Database
# Luego: Database → REST API → copiá URL y token.
UPSTASH_REDIS_REST_URL=https://TU_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=Tu_token_aquí

# ── n8n Webhook ───────────────────────────────────────────────────
# URL del webhook de producción (sin -test) — el workflow debe estar ACTIVO en n8n
N8N_WEBHOOK_URL=https://n8n.mygadministraciones.com.ar/webhook/7846a1f2-8f81-45a1-bdf5-f9fd6fe9c54b
